{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.TrackingTime/mcp-server",
  "description": "TrackingTime MCP server for profile, events, users, projects, tasks, customers, and services.",
  "version": "1.0.2",
  "websiteUrl": "https://trackingtime.co",
  "icons": [
    {
      "src": "https://trackingtime.co/wp-content/uploads/2024/09/Tracking-Time-Icon_512x512px-2.png",
      "sizes": ["any"]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.trackingtime.co/mcp",
      "headers": [
        {
          "name": "X-API-Key",
          "description": "TrackingTime APP Password",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ],
  "repository": {
    "url": "https://github.com/TrackingTime/mcp-server",
    "source": "github"
  }
}
